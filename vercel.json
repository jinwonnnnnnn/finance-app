{
  "installCommand": "npm install -g pnpm@10.28.0 && cd frontend && pnpm install",
  "buildCommand": "cd frontend && pnpm build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://precious-gentleness-production.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
